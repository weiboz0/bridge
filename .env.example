# Database
DATABASE_URL=postgresql://work@127.0.0.1:5432/bridge

# Environment classification (plan 050). Used by the Go API to gate
# the DEV_SKIP_AUTH startup guard: if DEV_SKIP_AUTH is set AND
# APP_ENV=production, the server refuses to start (DEV_SKIP_AUTH
# bypasses auth entirely → catastrophic if it leaks into prod).
# Set APP_ENV=production in production deployments. Absence is
# treated as "not production" (safe default for dev).
APP_ENV=development

# Plan 068 phase 1 — host-exposure declaration. Second layer of defense
# against DEV_SKIP_AUTH leaking onto a tunneled or shared dev server
# (review 010 §P0 #1 caught exactly that case on a tunneled review env).
# Values:
#   localhost (default) — server is bound to loopback / only reachable
#     locally. DEV_SKIP_AUTH is allowed.
#   exposed — server is reachable from outside the local machine
#     (tunneled via SSH, on a LAN, behind a public ingress, etc.).
#     If DEV_SKIP_AUTH is also set, the server refuses to start.
# Set BRIDGE_HOST_EXPOSURE=exposed on any deployment where
# `curl http://<server-host>:8002/healthz` works from a non-local
# machine — staging, demo servers, tunneled review envs.
BRIDGE_HOST_EXPOSURE=localhost

# Escape hatch for the BRIDGE_HOST_EXPOSURE guard above. Only set this
# when you DELIBERATELY want DEV_SKIP_AUTH active on a tunneled host
# (e.g., a private demo machine where you've fully internalized the
# trade-off). Default unset means the guard fires; setting "true"
# opens the hatch with a loud startup warning. Any other value is
# treated as unset.
ALLOW_DEV_AUTH_OVER_TUNNEL=

# Auth — Bridge's dev port is 3003 (CLAUDE.md: `PORT=3003 bun run dev`).
# If you change the port you also need to add the matching redirect URI
# in Google Cloud Console; otherwise sign-in fails with redirect_uri_mismatch.
NEXTAUTH_URL=http://localhost:3003
NEXTAUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32

# Trusted reverse-proxy CIDRs that may inject X-Forwarded-Proto (and have
# the Go backend honor it for canonical-cookie selection). Comma-separated.
# Empty = trust no proxy — safe default for local dev where requests hit
# the Go API directly. Set in production to the load balancer / ingress
# range (e.g. "10.0.0.0/8,fd00::/8"). The ingress proxy MUST also strip
# client-supplied X-Forwarded-Proto headers before forwarding — allowlist
# alone is insufficient.
TRUSTED_PROXY_CIDRS=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# Hocuspocus WebSocket (for real-time collaboration)
# Set to ws://<your-hostname>:4000 when accessing from another machine
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:4000

# Hocuspocus token secret (plan 053). Shared HMAC secret used by the Go API
# to sign short-lived realtime JWTs and by the Hocuspocus Node process to
# verify them on connect. Generate with `openssl rand -base64 32`. If unset,
# /api/realtime/token returns 503 and the legacy `userId:role` token format
# remains active. Required in staging/prod once the realtime-token flag flips.
HOCUSPOCUS_TOKEN_SECRET=

# Phase-4 cutover flag (plan 053). Set to 1 to make Hocuspocus reject any
# non-JWT (legacy `userId:role`) tokens. Leave unset / 0 during the rollout
# window so old browser tabs minted before the client-side rollout don't
# break.
HOCUSPOCUS_REQUIRE_SIGNED_TOKEN=

# Internal Go API base URL the Hocuspocus Node process uses for the
# server-to-server defense-in-depth recheck (POST /api/internal/realtime/auth).
# This URL is NOT browser-reachable. Defaults to localhost:8002 (the Go API's
# local port).
GO_INTERNAL_API_URL=http://localhost:8002

# Plan 065 — Bridge-issued session JWT.
#
# Auth.js completes sign-in (Google or credentials), then Next.js's Edge
# middleware lazily calls POST /api/internal/sessions on the Go API to mint
# a Bridge session token. The browser carries the resulting `bridge.session`
# cookie alongside Auth.js's encrypted JWE. Once the BRIDGE_SESSION_AUTH flag
# flips, Go middleware verifies this token instead of decrypting the JWE,
# closing the dual-implementation seam plans 050/053/PR-103 patched piecewise.
#
# Three secrets here, each with a distinct blast radius:
#
# BRIDGE_SESSION_SECRETS — comma-separated list. The first entry signs new
# tokens; every entry is tried during verification. To rotate without a
# 401 storm: deploy with the new secret prepended (e.g. "new,old"), wait
# one cookie TTL (7 days) for active sessions to re-mint under "new", then
# deploy with just "new". Generate each entry via `openssl rand -base64 32`.
# Distinct from NEXTAUTH_SECRET and HOCUSPOCUS_TOKEN_SECRET so each
# compromise stays independently contained. (Legacy single-name
# BRIDGE_SESSION_SECRET is also accepted for environments using the simpler
# form; the plural takes precedence when both are set.)
BRIDGE_SESSION_SECRETS=
# BRIDGE_SESSION_SECRET=  # legacy single-name fallback

# BRIDGE_INTERNAL_SECRET — bearer the Auth.js mint helper sends in the
# Authorization header on POST /api/internal/sessions. Distinct from
# HOCUSPOCUS_TOKEN_SECRET so a leak of the realtime callback bearer cannot
# forge session cookies. Generate via `openssl rand -base64 32`.
BRIDGE_INTERNAL_SECRET=

# BRIDGE_SESSION_AUTH — feature flag for the Phase-3 cutover. With OFF
# (default), Go middleware reads bridge.session opportunistically but still
# treats Auth.js JWE as primary. With ON ("1", "true", or "yes"),
# bridge.session becomes the authoritative cookie; an absent cookie falls
# back to JWE during rollout, an INVALID cookie returns 401 unconditionally
# (downgrade-attack defense — see plan 065 §"RequireAuth logic").
BRIDGE_SESSION_AUTH=

# LLM Backend Configuration
# Set LLM_BACKEND to switch providers. Supported values:
#   anthropic (default), openai, ark/doubao, aliyun/dashscope/qwen, nvidia/nim, openrouter
# Set LLM_MODEL to override the default model for the chosen backend.
# Set LLM_BASE_URL to override the API endpoint (for proxies or private deployments).
LLM_BACKEND=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=

# Provider API Keys (only the active backend's key is required)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ARK_API_KEY=
# DASHSCOPE_API_KEY=
# NVIDIA_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
