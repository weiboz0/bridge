# Database
DATABASE_URL=postgresql://work@127.0.0.1:5432/bridge

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-secret-with-openssl-rand-base64-32

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Redis
REDIS_URL=redis://localhost:6379

# LLM Backend Configuration
# Set LLM_BACKEND to switch providers. Supported values:
#   anthropic (default), openai, ark/doubao, aliyun/dashscope/qwen, nvidia/nim, openrouter
# Set LLM_MODEL to override the default model for the chosen backend.
# Set LLM_BASE_URL to override the API endpoint (for proxies or private deployments).
LLM_BACKEND=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_BASE_URL=

# Provider API Keys (only the active backend's key is required)
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# ARK_API_KEY=
# DASHSCOPE_API_KEY=
# NVIDIA_API_KEY=
# OPENROUTER_API_KEY=
